# Database
DATABASE_URL=postgresql+asyncpg://cc_user:cc_password@localhost:5432/cc_db
DATABASE_URL_SYNC=postgresql://cc_user:cc_password@localhost:5432/cc_db

# App
APP_NAME=CC Fund Platform
DEBUG=true
SECRET_KEY=change-me-in-production-use-random-string
API_V1_PREFIX=/api/v1

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# JWT Auth
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis (Phase 2)
REDIS_URL=redis://localhost:6379/0

# Celery (Phase 2)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
